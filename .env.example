# API keys for closed-source MLLM providers.
# Copy this file to `.env` and fill in the keys you actually use.

# OpenAI (GPT-4o / GPT-5 series)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Google (Gemini)
GOOGLE_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Custom proxy endpoint (optional). Used by api_models.py when the model
# config sets provider="custom".
CUSTOM_API_KEY=
CUSTOM_BASE_URL=

# Where the benchmark videos live on disk. The release parquet's
# `video_path` field is relative to this root.
# Default = ./data/videos
OVO_S_VIDEO_ROOT=

# Where to write the per-query frame cache (.npy files).
# Default = ./.frame_cache  — set to a fast local disk for best throughput.
OVO_S_FRAME_CACHE=

# Where local HF model weights live. If unset, models fall back to the
# HuggingFace cache (~/.cache/huggingface).
OVO_S_MODEL_ROOT=
